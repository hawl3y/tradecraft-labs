# ─── Site URL ─────────────────────────────────────────────────────────────────
# Used in metadataBase for OG tags, canonical URLs, and sitemap.
# Set to your production domain (with https://, no trailing slash).
# Falls back to the Vercel deployment URL if not set.
NEXT_PUBLIC_SITE_URL=https://tradecraftlabs.com

# ─── Analytics ────────────────────────────────────────────────────────────────
# Plausible analytics domain. If unset, no analytics script is injected.
# Must match the domain registered in your Plausible account (no https://, no path).
# Example: tradecraftlabs.com
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=tradecraftlabs.com
